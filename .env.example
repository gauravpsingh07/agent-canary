# Application
APP_NAME="Agent Canary"
APP_ENV=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET=replace-with-a-long-random-development-secret

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agent_canary

# AI providers
LLM_PROVIDER=mock
MOCK_LLM_MODEL=mock-agent-canary-v1
GEMINI_API_KEY=
GEMINI_MODEL=
GROQ_API_KEY=
GROQ_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
LLM_TIMEOUT_SECONDS=30

# Embeddings / vector search
EMBEDDING_PROVIDER=mock
MOCK_EMBEDDING_MODEL=mock-embedding-v1
GEMINI_EMBEDDING_MODEL=text-embedding-004
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=768
EMBEDDING_TIMEOUT_SECONDS=30
RAG_CHUNK_MAX_CHARS=1000
RAG_CHUNK_OVERLAP_CHARS=120
RETRIEVAL_DEFAULT_MIN_SCORE=0.25
RETRIEVAL_DEFAULT_MAX_RESULTS=5

# Optional background jobs
REDIS_URL=
